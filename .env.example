# Docker Compose
POSTGRES_DB=matchimban
POSTGRES_USER=matchimban
POSTGRES_PASSWORD=matchimban
POSTGRES_PORT=5432
REDIS_PORT=6379

# Spring app environment
DB_URL=jdbc:postgresql://localhost:5432/matchimban
DB_USERNAME=matchimban
DB_PASSWORD=matchimban
DB_POOL_MAX_SIZE=20

# Optional Redis config
REDIS_HOST=localhost
REDIS_PORT=6379
AWS_REGION=ap-northeast-2

# Chat image upload (S3)
CHAT_IMAGE_BUCKET=moyeobab-dev-chat-images
CHAT_IMAGE_PUBLIC_BASE_URL=
CHAT_IMAGE_PRESIGN_EXPIRES_SECONDS=120
CHAT_IMAGE_MAX_FILE_SIZE_BYTES=10485760
CHAT_IMAGE_ALLOWED_CONTENT_TYPES=image/jpeg,image/jpg,image/png,image/webp,image/gif

##kakao Oauth
KAKAO_CLIENT_ID=lpX...
KAKAO_REDIRECT_URI=http://localhost:8080/api/v1/auth/kakao/auth-code
KAKAO_CLIENT_SECRET=d9sg...
KAKAO_ADMIN_KEY=f980...
KAKAO_UNLINK_URL=https://kapi.kakao.com/v1/user/unlink
KAKAO_FRONTEND_REDIRECT_URL=http://localhost:5173
KAKAO_CONNECT_TIMEOUT=2s
KAKAO_READ_TIMEOUT=3s
CSRF_COOKIE_DOMAIN=

# JWT
JWT_SECRET=b8aff5b911fc14a53aacfa0828fb1e79306042a6b0c47fa231b81923997aa0d9
JWT_ISSUER=matchimban
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_COOKIE_NAME=access_token
JWT_REFRESH_COOKIE_NAME=refresh_token
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_COOKIE_SECURE=false # 배포 시 true
JWT_COOKIE_SAME_SITE=Lax

# Notification / Firebase (FCM)
# 배포 시 true 권장
NOTIFICATION_FIREBASE_ENABLED=false
FIREBASE_PROJECT_ID=moyeobab
# 아래 2개 중 하나만 설정하면 됨
FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=
FIREBASE_SERVICE_ACCOUNT_FILE=

# Notification workers (기본값 유지 가능)
NOTIFICATION_DISPATCH_ENABLED=true
NOTIFICATION_SCHEDULE_ENABLED=true
NOTIFICATION_RETENTION_ENABLED=true
